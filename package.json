{
  "name": "virgenherrera",
  "private": true,
  "packageManager": "pnpm@11.5.3+sha512.7ac1c919341c213a34dc0d02afb7143c5c26ac26ee8c4782deea821b8ac64d2134a081fd8941dae6e29bbb48f58dfc2b7fbceeccc07cb2f09d219d342a4969ed",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/virgenherrera/virgenherrera.git"
  },
  "engines": {
    "node": ">=24.15.0 <25",
    "pnpm": ">=11.0.0 <12"
  },
  "scripts": {
    "generate:readme": "pnpm --filter @virgenherrera/tool-readme-generator start",
    "generate:all": "pnpm --filter @virgenherrera/app-ghpages start && pnpm run generate:readme",
    "generate:recruiter-link": "pnpm --filter @virgenherrera/app-ghpages run generate:link",
    "build:ghpages": "pnpm --filter @virgenherrera/app-ghpages build",
    "build:app": "pnpm run build:ghpages",
    "preview:ghpages": "pnpm dlx http-server apps/ghpages/dist/app-ghpages/browser -o",
    "test": "pnpm run cleanup && pnpm run test:static && pnpm run test:dynamic && pnpm run test:e2e && pnpm run build:app",
    "test:static": "pnpm run securityCheck && pnpm run eslintCheck && pnpm run prettierCheck",
    "test:dynamic": "pnpm -r run test:dynamic",
    "test:e2e": "pnpm --filter @virgenherrera/tool-ghpages-e2e exec playwright install --with-deps chromium && pnpm --filter @virgenherrera/app-ghpages exec ng build --base-href / && pnpm --filter @virgenherrera/tool-ghpages-e2e run test:e2e",
    "test:doctor": "pnpm run cleanup && pnpm run test:static && pnpm run test:dynamic && pnpm run test:e2e && pnpm run build:app",
    "securityCheck": "pnpm audit --audit-level high",
    "eslintCheck": "pnpm -r run eslintCheck",
    "prettierCheck": "pnpm -r run prettierCheck",
    "cleanup": "rimraf coverage/",
    "securityFix": "pnpm update",
    "bumpDependencies": "pnpm run securityFix && pnpm dlx npm-check-updates@17 && pnpm run securityFix",
    "updatePnpm": "corepack up",
    "prepare": "husky",
    "lintStaged": "lint-staged"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "eslint": "10.4.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.6",
    "globals": "17.6.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.7",
    "prettier": "3.8.3",
    "rimraf": "6.1.3",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.0",
    "vitest": "4.1.8",
    "zod": "4.4.3"
  }
}
