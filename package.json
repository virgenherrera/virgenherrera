{
  "name": "virgenherrera",
  "version": "1.1.1",
  "description": "Personal monorepo",
  "author": "Hugo Virgen (https://github.com/virgenherrera)",
  "private": true,
  "license": "UNLICENSED",
  "homepage": "https://github.com/virgenherrera/virgenherrera#readme",
  "bugs": {
    "url": "https://github.com/virgenherrera/virgenherrera/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/virgenherrera/virgenherrera.git"
  },
  "contributors": [
    "Hugo Virgen (https://github.com/virgenherrera)"
  ],
  "packageManager": "pnpm@11.4.0+sha512.f0febc7e37552ab485494a914241b338e0b3580b93d54ce31f00933015880863129038a1b4ae4e414a0ee63ac35bf21197e990172c4a68256450b5636310968f",
  "engines": {
    "node": ">=24.13.0 <25",
    "pnpm": ">=11.0.0 <12"
  },
  "scripts": {
    "serve:resume": "pnpm --filter @vh/resume run start",
    "storybook": "pnpm --filter @vh/design-system run storybook",
    "build": "pnpm -r run --if-present build",
    "build:storybook": "pnpm --filter @vh/design-system run build:storybook",
    "generate:readme": "pnpm --filter @vh/app-readme run start",
    "test": "pnpm run cleanup && pnpm run build && pnpm run test:static && pnpm run test:types && pnpm run test:dynamic",
    "test:doctor": "pnpm run cleanup && pnpm -r run --if-present test:doctor",
    "test:static": "pnpm -r run --if-present test:static",
    "test:types": "pnpm -r run --if-present test:types",
    "test:unit": "pnpm -r run --if-present test:unit",
    "test:e2e": "pnpm -r run --if-present test:e2e",
    "test:dynamic": "pnpm run test:unit && pnpm run test:e2e",
    "eslintFix": "eslint --fix",
    "lintStaged": "lint-staged",
    "prepare": "husky",
    "prettierFix": "prettier --write",
    "securityCheck": "pnpm audit --audit-level high",
    "securityFix": "pnpm update",
    "updatePnpm": "corepack up",
    "cleanup": "pnpm -r run --if-present cleanup && rimraf artifacts/",
    "bumpDependencies": "pnpm run securityFix && pnpm dlx npm-check-updates@22.2.7 && pnpm run securityFix && pnpm run test",
    "release:patch": "node scripts/release.js patch",
    "release:minor": "node scripts/release.js minor",
    "release:major": "node scripts/release.js major"
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "@eslint/json": "catalog:",
    "@eslint/markdown": "catalog:",
    "@types/jest": "catalog:",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "eslint-plugin-prettier": "catalog:",
    "globals": "catalog:",
    "husky": "catalog:",
    "jest": "catalog:",
    "kill-port-process": "catalog:",
    "lint-staged": "catalog:",
    "prettier": "catalog:",
    "rimraf": "catalog:",
    "ts-jest": "catalog:",
    "ts-node": "catalog:",
    "tsconfig-paths": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:"
  }
}
