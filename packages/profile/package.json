{
  "name": "@vh/profile",
  "version": "0.1.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./data": "./src/data.ts",
    "./schema": "./src/schema.ts",
    "./server": "./src/get-profile.ts"
  },
  "scripts": {
    "test:doctor": "pnpm run test:static && pnpm run test:dynamic",
    "test:static": "pnpm run eslintCheck && pnpm run prettierCheck && tsc --noEmit",
    "test:unit": "jest",
    "test:dynamic": "pnpm run test:unit",
    "eslintCheck": "eslint .",
    "eslintFix": "eslint --fix",
    "prettierCheck": "prettier --check 'src/**/*.ts'",
    "prettierFix": "prettier --write",
    "cleanup": "echo 'no artifacts to clean'",
    "embed": "ts-node -r tsconfig-paths/register src/rag/embedder.ts",
    "export": "ts-node -r tsconfig-paths/register src/rag/export.ts"
  },
  "dependencies": {
    "gray-matter": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@huggingface/transformers": "catalog:"
  }
}
