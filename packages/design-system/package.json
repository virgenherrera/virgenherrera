{
  "name": "@vh/design-system",
  "version": "0.1.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "storybook": "ng run design-system:storybook",
    "build:storybook": "ng run design-system:build-storybook",
    "test:doctor": "pnpm run test:static && pnpm run test:types",
    "test:static": "pnpm run eslintCheck && pnpm run prettierCheck",
    "test:types": "tsc --noEmit",
    "eslintCheck": "eslint .",
    "eslintFix": "eslint --fix .",
    "prettierCheck": "prettier --check 'src/**/*.ts'",
    "prettierFix": "prettier --write",
    "cleanup": "rimraf artifacts/ storybook-static/"
  },
  "dependencies": {
    "@angular/common": "catalog:",
    "@angular/compiler": "catalog:",
    "@angular/core": "catalog:",
    "@angular/forms": "catalog:",
    "@angular/platform-browser": "catalog:",
    "@angular/router": "catalog:",
    "rxjs": "catalog:",
    "tslib": "catalog:"
  },
  "devDependencies": {
    "@vh/profile": "workspace:*",
    "@angular/build": "catalog:",
    "@angular/cli": "catalog:",
    "@angular/compiler-cli": "catalog:",
    "@angular/platform-browser-dynamic": "catalog:",
    "@angular-devkit/architect": "catalog:",
    "@angular-devkit/build-angular": "catalog:",
    "@angular-devkit/core": "catalog:",
    "@compodoc/compodoc": "catalog:",
    "@storybook/angular": "catalog:",
    "@storybook/addon-a11y": "catalog:",
    "@storybook/addon-docs": "catalog:",
    "@storybook/addon-onboarding": "catalog:",
    "eslint-plugin-storybook": "catalog:",
    "storybook": "catalog:",
    "tailwindcss": "catalog:",
    "@tailwindcss/postcss": "catalog:",
    "zone.js": "catalog:",
    "rimraf": "catalog:",
    "typescript": "catalog:"
  }
}
