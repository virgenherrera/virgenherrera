{
  "name": "@virgenherrera/app-ghpages",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "ng": "ng",
    "cleanup": "rimraf .angular dist",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test:static": "eslint 'src/**/*.ts' && prettier --check 'src/**/*.ts'",
    "test:unit": "vitest run",
    "test": "pnpm run test:static && pnpm run test:unit",
    "generate:link": "tsx scripts/generate-link.ts",
    "bumpDependencies": "pnpm dlx npm-check-updates"
  },
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/platform-server": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@angular/ssr": "^21.2.5",
    "@ngrx/signals": "^21.1.0",
    "date-fns": "^4.1.0",
    "jspdf": "^4.2.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@angular/build": "^21.2.5",
    "@angular/cli": "^21.2.5",
    "@angular/compiler-cli": "^21.2.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.5.0",
    "happy-dom": "^20.10.2",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.2"
  }
