{
  "name": "@virgenherrera/app-ghpages",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "ng": "ng",
    "cleanup": "rimraf .angular dist test-results playwright-report",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test:static": "eslint '{src,e2e}/**/*.ts' && prettier --check '{src,e2e}/**/*.ts'",
    "test:e2e": "ng build --configuration development && playwright test",
    "test": "pnpm run test:static && pnpm run test:e2e",
    "generate:link": "tsx scripts/generate-link.ts",
    "serve:ssr": "http-server dist/app-ghpages/browser -p 8080 --no-dotfiles"
  },
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/platform-server": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@angular/ssr": "^21.2.5",
    "@ngrx/signals": "^21.1.0",
    "jspdf": "^4.2.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@angular/build": "^21.2.5",
    "@angular/cli": "^21.2.5",
    "@angular/compiler-cli": "^21.2.0",
    "@playwright/test": "^1.52.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^20.17.19",
    "http-server": "^14.1.1",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.2"
  }
}
