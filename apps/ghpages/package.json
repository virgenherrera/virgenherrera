{
  "name": "@virgenherrera/app-ghpages",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "ng": "ng",
    "cleanup": "rimraf .angular dist",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test:static": "eslint 'src/**/*.ts' && prettier --check 'src/**/*.ts'",
    "test:unit": "vitest run",
    "test": "pnpm run test:static && pnpm run test:unit",
    "generate:link": "tsx scripts/generate-link.ts",
    "bumpDependencies": "pnpm dlx npm-check-updates"
  },
  "dependencies": {
    "@angular/common": "22.0.0",
    "@angular/compiler": "22.0.0",
    "@angular/core": "22.0.0",
    "@angular/forms": "22.0.0",
    "@angular/platform-browser": "22.0.0",
    "@angular/platform-server": "22.0.0",
    "@angular/router": "22.0.0",
    "@angular/ssr": "22.0.0",
    "date-fns": "4.1.0",
    "jspdf": "4.2.1",
    "rxjs": "7.8.2",
    "tslib": "2.8.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@angular/build": "22.0.0",
    "@angular/cli": "22.0.0",
    "@angular/compiler-cli": "22.0.0",
    "@tailwindcss/postcss": "4.3.0",
    "@types/node": "25.9.2",
    "prettier": "3.8.3",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.3"
  }
}
