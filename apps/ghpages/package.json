{
  "name": "@virgenherrera/app-ghpages",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "serve:ssr": "tsx scripts/serve.ts",
    "test:static": "eslint '{src,e2e}/**/*.ts' && prettier --check '{src,e2e}/**/*.ts'",
    "test:types": "tsc --noEmit -p tsconfig.app.json",
    "test:e2e": "pnpm run build && playwright test",
    "test": "pnpm run test:static && pnpm run test:types && pnpm run test:e2e"
  },
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/platform-server": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@angular/ssr": "^21.2.5",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.5",
    "@angular/cli": "^21.2.5",
    "@angular/compiler-cli": "^21.2.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^20.17.19",
    "http-server": "^14.1.1",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.2"
  }
}
