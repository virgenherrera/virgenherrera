{
  "name": "@vh/app-readme",
  "version": "0.2.0",
  "private": true,
  "main": "./src/main.ts",
  "types": "./src/main.ts",
  "exports": {
    ".": "./src/main.ts",
    "./app.module": "./src/app.module.ts",
    "./readme.service": "./src/readme.service.ts",
    "./github-schemas": "./src/github/github.schemas.ts"
  },
  "scripts": {
    "start": "ts-node -r tsconfig-paths/register src/main.ts",
    "test:doctor": "pnpm run test:static && pnpm run test:types",
    "test:static": "pnpm run eslintCheck && pnpm run prettierCheck",
    "test:types": "tsc --noEmit",
    "eslintCheck": "eslint .",
    "eslintFix": "eslint --fix",
    "prettierCheck": "prettier --check 'src/**/*.ts'",
    "prettierFix": "prettier --write",
    "cleanup": "echo 'no artifacts to clean'"
  },
  "dependencies": {
    "@nestjs/axios": "catalog:",
    "@nestjs/common": "catalog:",
    "@nestjs/core": "catalog:",
    "@vh/profile": "workspace:*",
    "axios": "catalog:",
    "reflect-metadata": "catalog:",
    "rxjs": "catalog:",
    "zod": "catalog:"
  }
}
