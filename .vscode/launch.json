{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Resume (Chrome)",
      "type": "chrome",
      "request": "launch",
      "preLaunchTask": "serve:resume",
      "postDebugTask": "kill-port:4200",
      "url": "http://localhost:4200",
      "webRoot": "${workspaceFolder}/apps/resume"
    },
    {
      "name": "Debug Resume (Edge)",
      "type": "msedge",
      "request": "launch",
      "preLaunchTask": "serve:resume",
      "postDebugTask": "kill-port:4200",
      "url": "http://localhost:4200",
      "webRoot": "${workspaceFolder}/apps/resume"
    },
    {
      "name": "Debug Resume (Firefox)",
      "type": "firefox",
      "request": "launch",
      "preLaunchTask": "serve:resume",
      "postDebugTask": "kill-port:4200",
      "url": "http://localhost:4200",
      "webRoot": "${workspaceFolder}/apps/resume"
    }
  ]
}
