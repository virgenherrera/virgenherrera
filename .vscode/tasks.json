{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "serve:resume",
      "type": "shell",
      "command": "pnpm run serve:resume",
      "isBackground": true,
      "problemMatcher": {
        "owner": "angular",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*Angular is running in development mode.*|.*Re-optimizing dependencies.*|.*Watch mode enabled.*",
          "endsPattern": ".*Application bundle generation complete.*|.*compiled successfully.*"
        }
      }
    },
    {
      "label": "kill-port:4200",
      "type": "shell",
      "command": "pnpm exec kill-port 4200",
      "presentation": {
        "reveal": "silent"
      }
    }
  ]
}
