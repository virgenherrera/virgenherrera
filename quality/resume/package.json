{
  "name": "@vh/quality-resume",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test:doctor": "pnpm run test:static && pnpm run test:types",
    "test:static": "pnpm run eslintCheck && pnpm run prettierCheck",
    "test:types": "tsc --noEmit",
    "test:e2e": "playwright test",
    "test:dynamic": "pnpm run test:e2e",
    "eslintCheck": "eslint .",
    "eslintFix": "eslint --fix",
    "prettierCheck": "prettier --check 'src/**/*.ts'",
    "prettierFix": "prettier --write",
    "test:report": "playwright show-report ../../artifacts/quality/resume/playwright-report",
    "cleanup": "rimraf ../../artifacts/quality/resume/"
  },
  "devDependencies": {
    "@playwright/test": "catalog:",
    "@vh/profile": "workspace:*",
    "@types/node": "catalog:",
    "http-server": "14.1.1",
    "rimraf": "catalog:",
    "typescript": "catalog:",
    "zod": "catalog:"
  }
}
