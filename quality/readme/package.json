{
  "name": "@vh/quality-readme",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "test:doctor": "pnpm run test:static && pnpm run test:types && pnpm run test:dynamic",
    "test:static": "pnpm run eslintCheck && pnpm run prettierCheck",
    "test:types": "tsc --noEmit",
    "test:unit": "jest",
    "test:dynamic": "pnpm run test:unit",
    "eslintCheck": "eslint .",
    "eslintFix": "eslint --fix",
    "prettierCheck": "prettier --check 'src/**/*.ts'",
    "prettierFix": "prettier --write",
    "cleanup": "rimraf artifacts/"
  },
  "dependencies": {
    "@nestjs/axios": "catalog:",
    "@nestjs/common": "catalog:",
    "@nestjs/core": "catalog:",
    "@vh/app-readme": "workspace:*",
    "axios": "catalog:",
    "reflect-metadata": "catalog:",
    "rxjs": "catalog:"
  },
  "devDependencies": {
    "rimraf": "catalog:"
  }
}
